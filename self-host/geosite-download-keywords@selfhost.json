{
  "version": 1,
  "rules": [
    {
      "domain_keyword": [
        "download",
        "update-binary",
        "mediafire",
        "pixeldrain",
        "1fichier"
      ],
      "domain_regex": [
        "^dl[-.].+",
        "^edgedl[-.].+",
        "^upd[-.].+",
        "^dist[-.].+",
        "^pkg[-.].+",
        "^archive[-.].+",
        "^mirror[-.].+",
        "^repo[-.].+",
        "^files[-.].+",
        "^cache[-.].+",
        "^p[0-9]+-content\\.icloud\\.com$",
        "^.*\\.tiktokcdn-us\\.com$"
      ]
    }
  ]
}