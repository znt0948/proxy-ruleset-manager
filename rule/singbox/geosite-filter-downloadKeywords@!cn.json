{
    "version": 1,
    "rules": [
        {
            "domain_regex": [
                "^dist[-.].+",
                "^archive[-.].+",
                "^cache[-.].+",
                "^dl[-.].+",
                "^content-download[-.].+",
                "^mirror[-.].+",
                "^edgedl[-.].+",
                "^files[-.].+",
                "^cdn-download[-.].+",
                "^pkg[-.].+",
                "^upd[-.].+",
                "^repo[-.].+"
            ]
        },
        {
            "domain_keyword": [
                "mediafire",
                "update-binary",
                "1fichier",
                "download",
                "pixeldrain"
            ]
        }
    ]
}