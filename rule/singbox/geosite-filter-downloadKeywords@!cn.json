{
    "version": 1,
    "rules": [
        {
            "domain_regex": [
                "^edgedl[-.].+",
                "^static[0-9]\\.squarespace\\.com$",
                "^files[-.].+",
                "^repo[-.].+",
                "^upd[-.].+",
                "^dist[-.].+",
                "^dl[-.].+",
                "^cache[-.].+",
                "^mirror[-.].+",
                "^archive[-.].+",
                "^p[0-9]+-content\\.icloud\\.com$",
                "^pkg[-.].+"
            ]
        },
        {
            "domain_keyword": [
                "download",
                "pixeldrain",
                "mediafire",
                "1fichier",
                "update-binary"
            ]
        }
    ]
}