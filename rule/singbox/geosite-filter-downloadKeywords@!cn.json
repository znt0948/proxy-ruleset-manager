{
    "version": 1,
    "rules": [
        {
            "domain_regex": [
                "^edgedl[-.].+",
                "^upd[-.].+",
                "^dist[-.].+",
                "^mirror[-.].+",
                "^cache[-.].+",
                "^pkg[-.].+",
                "^repo[-.].+",
                "^files[-.].+",
                "^p[0-9]+-content\\.icloud\\.com$",
                "^dl[-.].+",
                "^archive[-.].+"
            ]
        },
        {
            "domain_keyword": [
                "1fichier",
                "mediafire",
                "pixeldrain",
                "update-binary",
                "download"
            ]
        }
    ]
}