{
    "version": 1,
    "rules": [
        {
            "domain_regex": [
                "^files[-.].+",
                "^edgedl[-.].+",
                "^dist[-.].+",
                "^archive[-.].+",
                "^mirror[-.].+",
                "^pkg[-.].+",
                "^[a-z]{3}[0-9]+\\.mirror\\.jellyfin\\.org$",
                "^static[0-9]\\.squarespace\\.com$",
                "^upd[-.].+",
                "^p[0-9]+-content\\.icloud\\.com$",
                "^cache[-.].+",
                "^dl[-.].+",
                "^repo[-.].+"
            ]
        },
        {
            "domain_keyword": [
                "mediafire",
                "download",
                "update-binary",
                "pixeldrain",
                "1fichier"
            ]
        }
    ]
}