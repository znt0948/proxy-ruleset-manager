{
    "version": 1,
    "rules": [
        {
            "domain_regex": [
                "^cache[-.].+",
                "^upd[-.].+",
                "^p[0-9]+-content\\.icloud\\.com$",
                "^pkg[-.].+",
                "^static[0-9]\\.squarespace\\.com$",
                "^repo[-.].+",
                "^dist[-.].+",
                "^[a-z]{3}[0-9]+\\.mirror\\.jellyfin\\.org$",
                "^archive[-.].+",
                "^files[-.].+",
                "^dl[-.].+",
                "^mirror[-.].+",
                "^edgedl[-.].+"
            ]
        },
        {
            "domain_keyword": [
                "mediafire",
                "download",
                "pixeldrain",
                "1fichier",
                "update-binary"
            ]
        }
    ]
}